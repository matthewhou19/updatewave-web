# Default values target the local Supabase stack started by `npx supabase start`.
# These ANON / SERVICE_ROLE keys are the public demo keys built into the Supabase
# CLI — they are NOT secrets and are identical on every developer's machine.
# For remote Supabase / production, override every value below.

# ── Supabase (local stack via Docker) ────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# ── Stripe (test mode — leave blank to skip checkout flows in dev) ───
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── App URL ──────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Email (mailpit catches all sends locally — no real delivery) ─────
# Mailpit web UI: http://127.0.0.1:54324
RESEND_API_KEY=local-mailpit-no-real-send
AUTH_FROM_EMAIL=UpdateWave <auth@auth.updatewave.org>
AUTH_REDIRECT_URL=http://localhost:3000/auth/callback

# ── Admin lead review (/admin/leads) ─────────────────────────────────
# OPTIONAL. Comma-separated allowlist of emails allowed into the lead-review
# page (case-insensitive). Leave UNSET to default to the founder email, so prod
# needs no configuration. Set this only to add/override admins without a code
# change. Log in via the normal magic-link flow with an allowlisted email.
# ADMIN_EMAILS=matthew@updatewave.org
